{
  "dashboard": {
    "id": null,
    "title": "Cathedral ARKHE - Visão Geral",
    "tags": ["cathedral", "arkhe", "mcp", "resiliencia"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Health Check MCP Server",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up{job=\"cathedral-mcp\"}",
            "legendFormat": "Status",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "DLQ Size",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
        "targets": [
          {
            "expr": "dlq_size",
            "legendFormat": "Mensagens",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 100 },
                { "color": "red", "value": 1000 }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
        "targets": [
          {
            "expr": "circuit_breaker_state{state=\"open\"}",
            "legendFormat": "Aberto",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Requisições por Minuto (MCP)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(mcp_requests_total[1m])",
            "legendFormat": "Requisições",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "req/min"
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" }
        }
      },
      {
        "id": 5,
        "title": "Latência P95 (MCP)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(mcp_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Latência",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" }
        }
      },
      {
        "id": 6,
        "title": "Poison Pills Detectados (última hora)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "increase(poison_pills_detected_total[1h])",
            "legendFormat": "Total",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 7,
        "title": "Últimos Eventos (WormGraph)",
        "type": "logs",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "count(events_total) by (record_type)",
            "legendFormat": "{{record_type}}",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          }
        },
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "dedupStrategy": "none",
          "enableLogDetails": true
        }
      },
      {
        "id": 8,
        "title": "Uso de Memória (MCP)",
        "type": "graph",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{container=\"cathedral-mcp\"}",
            "legendFormat": "Memória",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 9,
        "title": "Taxa de Sucesso (Last-Effort)",
        "type": "stat",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "last_effort_success_total / (last_effort_success_total + last_effort_failure_total)",
            "legendFormat": "Sucesso",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.7 },
                { "color": "green", "value": 0.9 }
              ]
            }
          },
          "overrides": []
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  },
  "overwrite": true,
  "title": "Cathedral ARKHE - Visão Geral"
}
