FROM rust:1.80-slim AS builder
WORKDIR /app
COPY . .
# RUN cargo build --release --features "aegis,picoads"

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y libssl-dev ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/cathedral-agent /usr/local/bin/ || true
ENTRYPOINT ["cathedral-agent"]
